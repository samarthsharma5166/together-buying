// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


enum Role {
  USER
  BUYER_PREMIUM
  RM
  ADMIN
  SUPER_ADMIN
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  PAUSED
  SOLD_OUT
  ARCHIVED
}

enum PossessionStatus {
  PRE_LAUNCH
  UNDER_CONSTRUCTION
  READY_TO_MOVE
}

enum PropertyImageType {
  EXTERIOR
  AMENITY
  LOCATION_MAP
  CONSTRUCTION_UPDATE
  MASTER_PLAN
}

enum UnitType {
  BHK_1
  BHK_2
  BHK_3
  BHK_4
  BHK_5
  VILLA
  PLOT
  OFFICE
  SHOP
}

enum UnitImageType {
  FLOOR_PLAN
  INTERIOR
  BALCONY
  KITCHEN
  BEDROOM
  LIVING_ROOM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  BOOKED
  LOST
}

model User {
  id             String   @id @default(uuid())

  role           Role   @default(USER)  

  firstName      String   @db.VarChar(100) @map("first_name")
  lastName       String   @db.VarChar(100) @map("last_name")

  email          String   @unique @db.VarChar(255)
  phone          String   @unique @db.VarChar(15)

  password       String  @db.VarChar(255) @map("password_hash")
  avatarUrl      String?  @map("avatar_url")

  addressLine1   String?  @db.VarChar(100) @map("address_line_1")
  addressLine2   String?  @db.VarChar(100) @map("address_line_2")
  city           String?  @db.VarChar(100) @map("city")
  state          String?  @db.VarChar(100) @map("state")
  pincode        String?  @db.VarChar(6) @map("pincode")


  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at") 

  @@map("users")
}

model Property {
  id                  String @id @default(uuid()) @db.Uuid

  developerId         String @db.Uuid
  createdById         String @db.Uuid

  title               String @db.VarChar(255)
  slug                String @unique @db.VarChar(255)

  description         String? @db.Text

  propertyType        PropertyType
  status              PropertyStatus

  city                String @db.VarChar(100)
  locality            String @db.VarChar(100)
  address             String @db.Text

  latitude            Decimal? @db.Decimal(10,8)
  longitude           Decimal? @db.Decimal(11,8)

  reraNumber          String @db.VarChar(100)
  reraState           String @db.VarChar(50)

  possessionDate      DateTime? @db.Date
  possessionStatus    PossessionStatus

  minPrice            BigInt
  maxPrice            BigInt

  totalUnits          Int?

  isFeatured          Boolean @default(false)
  isPreLaunch         Boolean @default(false)

  metaTitle           String? @db.VarChar(255)
  metaDescription     String? @db.Text

  createdAt           DateTime @default(now()) @db.Timestamptz
  updatedAt           DateTime @updatedAt @db.Timestamptz

  developer           User @relation("DeveloperProperties", fields: [developerId], references: [id])
  createdBy           User @relation("CreatedProperties", fields: [createdById], references: [id])

  images              PropertyImage[]
  units               PropertyUnit[]
  // amenities           PropertyAmenity[]
  // documents           PropertyDocument[]
  // leads               PropertyLead[]
  // groupBuy            PropertyGroupBuy?

  @@map("properties")
}


model PropertyImage {
  id          String @id @default(uuid()) @db.Uuid

  propertyId  String @db.Uuid

  imageUrl    String @db.Text

  caption     String? @db.VarChar(255)

  imageType   PropertyImageType

  sortOrder   Int @default(0)

  createdAt   DateTime @default(now()) @db.Timestamptz

  property Property @relation(fields: [propertyId],references: [id],onDelete: Cascade)

  @@map("property_images")
}


model PropertyUnit {
  id                String @id @default(uuid()) @db.Uuid

  propertyId        String @db.Uuid

  unitType          UnitType

  carpetAreaSqft    Decimal @db.Decimal(8,2)

  superAreaSqft     Decimal? @db.Decimal(8,2)

  price             BigInt

  availableUnits    Int?

  createdAt         DateTime @default(now()) @db.Timestamptz

  property Property @relation(fields: [propertyId],references: [id],onDelete: Cascade)

  images UnitImage[]

  @@map("property_units")
}

model UnitImage {
  id          String @id @default(uuid()) @db.Uuid

  unitId      String @db.Uuid

  imageUrl    String @db.Text

  imageType   UnitImageType

  caption     String? @db.VarChar(255)

  sortOrder   Int @default(0)

  unit PropertyUnit @relation(fields: [unitId],references: [id],onDelete: Cascade)

  @@map("unit_images")
}


enum PartnershipStatus {
  ACTIVE
  PAUSED
  TERMINATED
}

model Developer {
  id                 String @id @default(uuid()) @db.Uuid

  companyName        String @map("company_name") @db.VarChar(255)
  slug               String @unique @db.VarChar(255)

  logoUrl            String? @map("logo_url") @db.Text
  bannerImageUrl     String? @map("banner_image_url") @db.Text

  contactName        String @map("contact_name") @db.VarChar(100)
  contactEmail       String @unique @map("contact_email") @db.VarChar(255)
  contactPhone       String @unique @map("contact_phone") @db.VarChar(15)

  websiteUrl         String? @map("website_url") @db.Text

  establishedYear    Int? @map("established_year")
  description        String? @db.Text

  headquartersCity   String? @map("headquarters_city") @db.VarChar(100)

  reraRegistered     Boolean @default(false) @map("rera_registered")

  partnershipStatus  PartnershipStatus @default(ACTIVE) @map("partnership_status")

  partnershipStart   DateTime? @map("partnership_start") @db.Date

  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  properties         Property[]

  @@map("developers")
}