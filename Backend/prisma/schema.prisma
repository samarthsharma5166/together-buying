// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


enum Role {
  USER
  BUYER_PREMIUM
  RM
  ADMIN
  SUPER_ADMIN
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  PAUSED
  SOLD_OUT
  ARCHIVED
}

enum PossessionStatus {
  PRE_LAUNCH
  UNDER_CONSTRUCTION
  READY_TO_MOVE
}

enum PropertyImageType {
  EXTERIOR
  AMENITY
  LOCATION_MAP
  CONSTRUCTION_UPDATE
  MASTER_PLAN
}

enum UnitType {
  BHK_1
  BHK_2
  BHK_3
  BHK_4
  BHK_5
  VILLA
  PLOT
  OFFICE
  SHOP
}

enum UnitImageType {
  FLOOR_PLAN
  INTERIOR
  BALCONY
  KITCHEN
  BEDROOM
  LIVING_ROOM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  BOOKED
  LOST
}

model User {
  id             String   @id @default(uuid())

  role           Role   @default(USER)  

  firstName      String   @map("first_name")
  lastName       String   @map("last_name")

  email          String   @unique
  phone          String   @unique

  password       String  @map("password_hash")
  avatarUrl      String?  @map("avatar_url")

  addressLine1   String?  @map("address_line_1")
  addressLine2   String?  @map("address_line_2")
  city           String?  @map("city")
  state          String?  @map("state")
  pincode        String?  @map("pincode")


  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at") 
  createdProperties Property[] @relation("CreatedProperties")

  @@map("users")
}

model Property {
  id                  String @id @default(uuid())

  developerId         String
  createdById         String

  title               String
  slug                String @unique

  description         String?

  propertyType        PropertyType
  status              PropertyStatus

  city                String
  locality            String
  address             String

  latitude            Decimal?
  longitude           Decimal?

  reraNumber          String
  reraState           String

  possessionDate      DateTime?
  possessionStatus    PossessionStatus

  minPrice            BigInt
  maxPrice            BigInt

  totalUnits          Int?

  isFeatured          Boolean @default(false)
  isPreLaunch         Boolean @default(false)

  metaTitle           String?
  metaDescription     String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  developer           Developer @relation("DeveloperProperties", fields: [developerId], references: [id])
  createdBy           User @relation("CreatedProperties", fields: [createdById], references: [id])

  images              PropertyImage[]
  units               PropertyUnit[]
  // amenities           PropertyAmenity[]
  // documents           PropertyDocument[]
  // leads               PropertyLead[]
  // groupBuy            PropertyGroupBuy?

  @@map("properties")
}


model PropertyImage {
  id          String @id @default(uuid())

  propertyId  String

  imageUrl    String

  caption     String?

  imageType   PropertyImageType

  sortOrder   Int @default(0)

  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId],references: [id],onDelete: Cascade)

  @@map("property_images")
}


model PropertyUnit {
  id                String @id @default(uuid())

  propertyId        String

  unitType          UnitType

  carpetAreaSqft    Decimal

  superAreaSqft     Decimal?

  price             BigInt

  availableUnits    Int?

  createdAt         DateTime @default(now())

  property Property @relation(fields: [propertyId],references: [id],onDelete: Cascade)

  images UnitImage[]

  @@map("property_units")
}

model UnitImage {
  id          String @id @default(uuid())

  unitId      String

  imageUrl    String

  imageType   UnitImageType

  caption     String?

  sortOrder   Int @default(0)

  unit PropertyUnit @relation(fields: [unitId],references: [id],onDelete: Cascade)

  @@map("unit_images")
}


enum PartnershipStatus {
  ACTIVE
  PAUSED
  TERMINATED
}

model Developer {
  id                 String @id @default(uuid())

  companyName        String @map("company_name")
  slug               String @unique

  logoUrl            String? @map("logo_url")
  bannerImageUrl     String? @map("banner_image_url")

  contactName        String @map("contact_name")
  contactEmail       String @unique @map("contact_email")
  contactPhone       String @unique @map("contact_phone")

  websiteUrl         String? @map("website_url")

  establishedYear    Int? @map("established_year")
  description        String?

  headquartersCity   String? @map("headquarters_city")

  reraRegistered     Boolean @default(false) @map("rera_registered")

  partnershipStatus  PartnershipStatus @default(ACTIVE) @map("partnership_status")

  partnershipStart   DateTime? @map("partnership_start")

  createdAt          DateTime @default(now()) @map("created_at")

  updatedAt          DateTime @updatedAt @map("updated_at")

  properties         Property[] @relation("DeveloperProperties")

  @@map("developers")
}